InputStream = interface {
	available: sys.types.signature(sys.types.int)
	read: sys.types.signature(sys.types.int)
	close: sys.types.signature(sys.types.any)
}

OutputStream = interface {
	write: sys.types.signature(sys.types.any, sys.types.int)
	flush: sys.types.signature(sys.types.any)
	close: sys.types.signature(sys.types.any)
}