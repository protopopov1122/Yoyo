print("Yoyo REPL");
print("Use '\\' at the and of line to write multiline code. Type 'exit()' to stop.");
in = "\\";
scope = object;
do {
	console.print(">>>");
	while in.endsWith("\\") {
		console.print("\t");
		in = in[0:in.length-1];
		in += read();
	}
	print({
		var out;
		try out = with scope eval(in);
		catch e e.toString()+(if e.log.length>0 "\n"+e.log else "")+"\n"+e.trace
		else if out != null
			out
		    else
			""
	});
	in = "\\"
}
